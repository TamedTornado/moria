(
    schema_version: 1,
    bindings: [
        (physical: Keyboard(W), action: Player(Move), value: PositiveY, modifier: None),
        (physical: Keyboard(A), action: Player(Move), value: NegativeX, modifier: None),
        (physical: Keyboard(S), action: Player(Move), value: NegativeY, modifier: None),
        (physical: Keyboard(D), action: Player(Move), value: PositiveX, modifier: None),
        (physical: Keyboard(LeftShift), action: Player(Sprint), value: Pressed, modifier: None),
        (physical: Keyboard(Space), action: Player(Jump), value: Pressed, modifier: None),
        (physical: Mouse(CapturedMotion), action: Player(Orbit), value: Continuous, modifier: None),
        (physical: Mouse(Wheel), action: Player(Zoom), value: Continuous, modifier: None),
        (physical: Keyboard(G), action: Debug(Dig), value: Pressed, modifier: None),
        (physical: Mouse(LeftButton), action: Debug(Dig), value: Pressed, modifier: None),
        (physical: Keyboard(P), action: Debug(Place), value: Pressed, modifier: None),
        (physical: Mouse(RightButton), action: Debug(Place), value: Pressed, modifier: None),
        (physical: Keyboard(LeftBracket), action: Debug(SelectPreviousMaterial), value: Pressed, modifier: None),
        (physical: Keyboard(RightBracket), action: Debug(SelectNextMaterial), value: Pressed, modifier: None),
        (physical: Keyboard(F1), action: Debug(ToggleBrickBounds), value: Pressed, modifier: None),
        (physical: Keyboard(F2), action: Debug(ToggleRawVoxels), value: Pressed, modifier: None),
        (physical: Keyboard(F3), action: Debug(ToggleStreamingBands), value: Pressed, modifier: None),
        (physical: Keyboard(Minus), action: Ui(AdjustTimeOfDay), value: Negative, modifier: None),
        (physical: Keyboard(Equal), action: Ui(AdjustTimeOfDay), value: Positive, modifier: None),
        (physical: Keyboard(Tab), action: Ui(ToggleTimeSliderFocus), value: Pressed, modifier: None),
        (physical: Keyboard(F5), action: Debug(Save), value: Pressed, modifier: None),
        (physical: Keyboard(F9), action: Debug(Load), value: Pressed, modifier: None),
        (physical: Gamepad(LeftStick), action: Player(Move), value: Continuous, modifier: None),
        (physical: Gamepad(LeftStickPress), action: Player(Sprint), value: Pressed, modifier: None),
        (physical: Gamepad(South), action: Player(Jump), value: Pressed, modifier: None),
        (physical: Gamepad(RightStick), action: Player(Orbit), value: Continuous, modifier: None),
        (physical: Gamepad(TriggerDifference), action: Player(Zoom), value: Continuous, modifier: None),
        (physical: Gamepad(RightShoulder), action: Debug(Dig), value: Pressed, modifier: None),
        (physical: Gamepad(LeftShoulder), action: Debug(Place), value: Pressed, modifier: None),
        (physical: Gamepad(DPadLeft), action: Debug(SelectPreviousMaterial), value: Pressed, modifier: None),
        (physical: Gamepad(DPadRight), action: Debug(SelectNextMaterial), value: Pressed, modifier: None),
        (physical: Gamepad(DPadDown), action: Ui(AdjustTimeOfDay), value: Negative, modifier: Some(Debug)),
        (physical: Gamepad(DPadUp), action: Ui(AdjustTimeOfDay), value: Positive, modifier: Some(Debug)),
    ],
    stick_dead_zone: 0.15,
    mouse_orbit_sensitivity_degrees_per_unit: 0.12,
    gamepad_orbit_sensitivity_degrees_per_second: 150.0,
)
