        (physical: Keyboard(LeftShift), semantic: Player(Sprint)),
        (physical: GamepadButton(LeftStick), semantic: Player(Sprint)),
        (physical: Keyboard(Space), semantic: Player(Jump)),
        (physical: GamepadButton(South), semantic: Player(Jump)),
        (physical: MouseMotion, semantic: Player(OrbitX)),
        (physical: GamepadAxis(RightStickX), semantic: Player(OrbitX)),
        (physical: GamepadAxis(RightStickY), semantic: Player(OrbitY)),
        (physical: MouseWheel, semantic: Player(ZoomIn)),
        (physical: GamepadAxis(RightTrigger), semantic: Player(ZoomIn)),
        (physical: GamepadAxis(LeftTrigger), semantic: Player(ZoomOut)),
        (physical: Keyboard(G), semantic: Debug(Dig)),
        (physical: MouseButton(Left), semantic: Debug(Dig)),
        (physical: GamepadButton(RightShoulder), semantic: Debug(Dig)),
        (physical: Keyboard(P), semantic: Debug(Place)),
        (physical: MouseButton(Right), semantic: Debug(Place)),
        (physical: GamepadButton(LeftShoulder), semantic: Debug(Place)),
        (physical: Keyboard(LeftBracket), semantic: Debug(SelectPreviousMaterial)),
        (physical: GamepadButton(DPadLeft), semantic: Debug(SelectPreviousMaterial)),
        (physical: Keyboard(RightBracket), semantic: Debug(SelectNextMaterial)),
        (physical: GamepadButton(DPadRight), semantic: Debug(SelectNextMaterial)),
        (physical: Keyboard(F1), semantic: Debug(ToggleBrickBounds)),
        (physical: Keyboard(F2), semantic: Debug(ToggleRawVoxels)),
        (physical: Keyboard(F3), semantic: Debug(ToggleStreamingBands)),
        (physical: Keyboard(Minus), semantic: Ui(AdjustTimeOfDayDown)),
        (physical: GamepadButton(DPadDown), semantic: Ui(AdjustTimeOfDayDown)),
        (physical: Keyboard(Equals), semantic: Ui(AdjustTimeOfDayUp)),
        (physical: GamepadButton(DPadUp), semantic: Ui(AdjustTimeOfDayUp)),
        (physical: Keyboard(Tab), semantic: Ui(ToggleTimeSliderFocus)),
